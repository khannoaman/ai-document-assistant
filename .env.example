# --- Secrets (leave blank / unset for providers you're not using) ---
GOOGLE_API_KEY=
HUGGINGFACEHUB_API_TOKEN=
GROQ_API_KEY=
GROQ_FALLBACK_API_KEY=
QDRANT_API_KEY=
QDRANT_CLUSTER_ENDPOINT=

# --- Tunables (all optional, defaults shown; see app/config.py) ---
QDRANT_PORT=443
COLLECTION_NAME=ai_document_assistant_vector_store

EMBEDDING_PROVIDER=huggingface
HUGGINGFACE_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
GEMINI_EMBEDDING_MODEL=models/embedding-001

CHUNK_SIZE=800
CHUNK_OVERLAP=100
MIN_CONTENT_LENGTH=20
